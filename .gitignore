# ============================================================
# DADOS SENSÍVEIS — NÃO VERSIONAR (LGPD)
# A pasta Material/ contém peças REAIS com nome, CPF e NB de
# assistidos (inclusive menor). Fica somente local.
# ============================================================
Material/
*_extr.txt
*.original.md

# Documentos com dados pessoais em qualquer pasta
*.pdf
*.docx
*.jpeg
*.jpg
*.png

# Exceções: assets da skill de formatação (institucionais, sem dado pessoal)
!skills/formatacao-docx/assets/
!skills/formatacao-docx/assets/**
!skills/**/*.png
!skills/**/*.jpg
!skills/**/*.docx
!skills/**/*.ttf

# Saída de peças geradas (pode conter dados do assistido) — NUNCA versionar
saida/

# Sistema / temporários
Thumbs.db
desktop.ini
.DS_Store
~$*

# Python cache
__pycache__/
*.pyc
